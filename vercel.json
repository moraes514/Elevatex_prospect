{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/apps/web/dist/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/apps/web/dist/index.html"
    }
  ],
  "functions": {
    "api/index.ts": {
      "includeFiles": "apps/api/**"
    }
  }
}
